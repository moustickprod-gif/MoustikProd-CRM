{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.png",  "use": "@vercel/static" },
    { "src": "*.ico",  "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/claude",           "dest": "/api/claude.js" },
    { "src": "/api/send-email",       "dest": "/api/send-email.js" },
    { "src": "/api/notion",           "dest": "/api/notion.js" },
    { "src": "/api/sign",             "dest": "/api/sign.js" },
    { "src": "/api/submit-signature",  "dest": "/api/submit-signature.js" },
    { "src": "/api/stripe-checkout",   "dest": "/api/stripe-checkout.js" },
    { "src": "/api/stripe-webhook",    "dest": "/api/stripe-webhook.js" },
    { "src": "/sign.html",            "dest": "/sign.html" },
    { "src": "/logo.png",             "dest": "/logo.png" },
    { "src": "/(.*)",                 "dest": "/index.html" }
  ]
}
