# ══════════════════════════════════════════════
# Variables d'environnement — Moustikprod CRM
# ══════════════════════════════════════════════
# Ce fichier est un EXEMPLE. Ne pas le renommer en .env.
# Les vraies valeurs sont configurées directement sur Vercel :
#   → https://vercel.com/dashboard > moustikprod-crm > Settings > Environment Variables
#   → Ou via CLI : vercel env add BREVO_API_KEY
# ══════════════════════════════════════════════

# Brevo — Envoi d'emails automatiques (confirmations de signature, relances)
# Trouver la clé : https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# Les clés suivantes sont gérées côté FRONTEND
# (configurées dans l'interface CRM > Paramètres)
# Elles ne sont PAS des variables d'environnement Vercel.
# ──────────────────────────────────────────────

# Firebase — déjà intégré dans index.html (pas de variable nécessaire)
# FIREBASE_API_KEY=AIzaSy...  ← déjà dans le code

# Anthropic Claude — configuré dans les Paramètres de l'interface CRM
# ANTHROPIC_API_KEY=sk-ant-...

# Notion — configuré dans les Paramètres de l'interface CRM
# NOTION_TOKEN=secret_...
